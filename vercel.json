{
  "version": 2,
  "rewrites": [
    { "source": "/api/patients/:path*", "destination": "/api/patients.js" },
    { "source": "/api/sessions/:path*", "destination": "/api/sessions.js" },
    { "source": "/api/professionals/:path*", "destination": "/api/professionals.js" },
    { "source": "/api/pathologies/:path*", "destination": "/api/pathologies.js" },
    { "source": "/api/treatments/:path*", "destination": "/api/treatments.js" },
    { "source": "/api/stats/:path*", "destination": "/api/stats.js" },
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
