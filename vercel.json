{
  "version": 2,
  "routes": [
    { "src": "/api/professionals/(.*)", "dest": "/api/professionals.js" },
    { "src": "/api/professionals", "dest": "/api/professionals.js" },
    { "src": "/api/pathologies/(.*)", "dest": "/api/pathologies.js" },
    { "src": "/api/pathologies", "dest": "/api/pathologies.js" },
    { "src": "/api/treatments/(.*)", "dest": "/api/treatments.js" },
    { "src": "/api/treatments", "dest": "/api/treatments.js" },
    { "src": "/api/patients/(.*)", "dest": "/api/patients.js" },
    { "src": "/api/patients", "dest": "/api/patients.js" },
    { "src": "/api/sessions/patient/(.*)", "dest": "/api/sessions.js" },
    { "src": "/api/sessions/batch", "dest": "/api/sessions.js" },
    { "src": "/api/sessions/(.*)", "dest": "/api/sessions.js" },
    { "src": "/api/sessions", "dest": "/api/sessions.js" },
    { "src": "/api/stats/summary", "dest": "/api/stats.js" },
    { "src": "/assets/(.*)", "dest": "/dist/assets/$1" },
    { "src": "/(.*)\\.(.+)$", "dest": "/dist/$1.$2" },
    { "src": "/(.*)", "dest": "/dist/index.html" }
  ]
}
